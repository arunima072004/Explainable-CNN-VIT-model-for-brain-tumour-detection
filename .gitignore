# Model weights — tracked via Git LFS
# backend/*.pth files (single-file format)
# backend/vit_binary_best/ and backend/cnn_tumor_type_best/ (zipfile folder format)
# These are NOT ignored — Git LFS handles the large file upload

# Python
__pycache__/
*.py[cod]
*.egg-info/
.env
venv/
.venv/
backend/.demo_mode

# Frontend
frontend/node_modules/
frontend/dist/

# OS
.DS_Store
Thumbs.db

# Loose test images and reports in root
*.jpg
*.jpeg
*.png
*.webp
*.pdf
